# ============================================================
# Sistem Monitoring Tinggi Air - Backend Configuration
# ============================================================
# Copy file ini menjadi .env dan sesuaikan nilainya.

# -- Server --
PORT=3000
NODE_ENV=development

# -- PostgreSQL Database --
DB_HOST=localhost
DB_PORT=5432
DB_NAME=water_monitoring
DB_USER=postgres
DB_PASSWORD=your_password_here

# -- CORS --
# Comma-separated list of allowed origins (kosongkan untuk allow all)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
